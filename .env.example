# Port to run the local server on
PORT=3000

# Supabase PostgreSQL URI Connection String (Transaction Pooler recommended)
# You can find this in Supabase Project Settings > Database > Connection String (URI)
# Make sure to replace [YOUR-PASSWORD] with the database password you set during project creation.
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
